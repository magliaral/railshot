# ============================================================
# Images: block everything except rail.png and assets/
# ============================================================
# rail.png and the assets/ folder (logo, favicon) are tracked.
# All other photos, screenshots, test outputs etc. stay local.
*.png
*.jpg
*.jpeg
*.gif
*.bmp
*.tif
*.tiff
*.webp
*.svg
*.ico
*.heic
*.raw

# Negation: explicitly track rail.png and the assets folder
!rail.png
!assets/
!assets/**

# ============================================================
# Claude Code / AI assistant files
# ============================================================
# These contain conversation history, planning, and prompts
# that should not be in a public repo.
.claude/
.claude_code/
CLAUDE.md
CLAUDE.local.md
.aider*
.cursor/
.cursorignore
.cursorrules
.continue/
.copilot/
.github-copilot/
.codeium/
.windsurf/
.tabnine/

# AI conversation logs and exports
chat_history/
conversations/
*.claude.md
*_claude.md
claude-*.md
*-claude.md

# Plan/scratch/notes files commonly used with AI
PLAN.md
SCRATCH.md
NOTES.md
TODO.md
.scratch/
.notes/
plan_*.md
prompt_*.md
*.prompt.md
*.scratch
*.scratchpad
.plan
.notes

# Skill / instruction files (project-specific to your setup)
*.skill
*.skill.md
.skills/
SKILL.md

